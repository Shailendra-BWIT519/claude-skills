# Toggles for claude-workflow/gates/code-check.sh — true/false only, no script edits needed.
RUN_TYPECHECK=true
RUN_LINT=true
RUN_TEST=true
RUN_FORMAT=false

# Frontend/UI projects only — leave false (or delete the corresponding
# run_check lines in code-check.sh) for backend-only projects. See the
# CUSTOMIZE comment in code-check.sh before enabling either.
RUN_A11Y=false
RUN_VISUAL_REGRESSION=false

# Max lines of a failing check's output to print (repeated boilerplate from
# tools like Jest can otherwise dump hundreds of lines per failure).
MAX_OUTPUT_LINES=80
